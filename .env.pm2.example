# PM2 local configuration — copy this file to .env.pm2 and fill in the values.
# .env.pm2 is NOT checked into version control.

# Absolute path to the node binary PM2 should use to run the server.
# Find yours with:  which node
# If you use nvm:   /Users/<you>/.nvm/versions/node/<version>/bin/node
NODE_BINARY=
