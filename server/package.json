{
  "name": "line-dance-api",
  "version": "1.0.0",
  "description": "Line Dance Choreography Search API",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate": "node migrations/run-migrations.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "init-db": "node init-db.js",
    "init-dance-groups-db": "node init-dance-groups-db.js",
    "init-all": "npm run init-db && npm run init-dance-groups-db"
  },
  "dependencies": {
    "body-parser": "^2.0.0",
    "cors": "^2.8.5",
    "express": "^5.0.0",
    "pdfkit": "^0.18.0",
    "qrcode": "^1.5.4",
    "sqlite3": "^6.0.0",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@emnapi/core": "^1.9.1",
    "@emnapi/runtime": "^1.9.1",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2",
    "vitest": "^4.1.2"
  }
}
